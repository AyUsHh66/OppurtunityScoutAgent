# Business Agent 2.0 - Development Environment
# Use this for local development
# Copy to .env to activate

ENVIRONMENT=development
DEBUG=true

# Local services
OLLAMA_MODEL=phi
OLLAMA_BASE_URL=http://localhost:11434
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_NAME=opportunity_scout_collection

# Optional: Use mock APIs for development
HUNTER_API_KEY=test_key
REDDIT_CLIENT_ID=test_id
REDDIT_CLIENT_SECRET=test_secret

# Discord (for testing)
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=

# Logging
LOG_LEVEL=DEBUG
LOG_FILE=logs/business_agent.log

# Job sources
JOB_SOURCES=rss

# Security
FASTAPI_ADMIN_KEY=dev-admin-key-change-in-production
