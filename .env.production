# Business Agent 2.0 - Production Environment
# Configure all secrets before deploying
# KEEP THIS FILE SECURE - Contains production credentials

ENVIRONMENT=production
DEBUG=false

# Production services (use secure URLs)
OLLAMA_MODEL=mistral
OLLAMA_BASE_URL=http://ollama:11434
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION_NAME=opportunity_scout_collection

# Production API Keys (Set in deployment)
HUNTER_API_KEY=${HUNTER_API_KEY_PROD}
REDDIT_CLIENT_ID=${REDDIT_CLIENT_ID_PROD}
REDDIT_CLIENT_SECRET=${REDDIT_CLIENT_SECRET_PROD}
DISCORD_BOT_TOKEN=${DISCORD_BOT_TOKEN_PROD}
DISCORD_CHANNEL_ID=${DISCORD_CHANNEL_ID_PROD}
TRELLO_API_KEY=${TRELLO_API_KEY_PROD}
TRELLO_TOKEN=${TRELLO_TOKEN_PROD}
NOTION_API_KEY=${NOTION_API_KEY_PROD}

# Production Logging
LOG_LEVEL=INFO
LOG_FILE=/var/log/business_agent/business_agent.log

# Job sources
JOB_SOURCES=reddit,hackernews,rss,linkedin

# Security - MUST be changed in production
FASTAPI_ADMIN_KEY=${FASTAPI_ADMIN_KEY_PROD}

# Database (optional: use external database)
# DATABASE_URL=postgresql://user:pass@db:5432/business_agent

# Monitoring (optional)
# SENTRY_DSN=https://your_sentry_dsn
# PROMETHEUS_ENABLED=true

# Rate limiting
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW=60
