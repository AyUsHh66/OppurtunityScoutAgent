# Business Agent 2.0 - Environment Configuration
# Copy this file to .env and fill in your actual values

# ===== ENVIRONMENT =====
ENVIRONMENT=development  # development, staging, production
DEBUG=false

# ===== LLM Configuration =====
OLLAMA_MODEL=phi  # phi or mistral - mistral is more accurate but slower
OLLAMA_BASE_URL=http://localhost:11434

# ===== Vector Database =====
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_NAME=opportunity_scout_collection

# ===== Logging =====
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FILE=logs/business_agent.log

# ===== Job Search Configuration =====
JOB_SOURCES=reddit,rss,hackernews  # Comma-separated: reddit, rss, hackernews, linkedin
JOB_LOCATION=Remote
ENRICH_WITH_HUNTER=true
ENRICH_WITH_CLEARBIT=false

# ===== Notification Configuration =====
ENABLE_DISCORD=true
ENABLE_EMAIL=false
ENABLE_TRELLO=false
ENABLE_NOTION=false

# Discord
DISCORD_BOT_TOKEN=your_discord_bot_token
DISCORD_CHANNEL_ID=your_discord_channel_id

# Email (for notifications)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_FROM_EMAIL=your_email@gmail.com
SMTP_FROM_PASSWORD=your_app_password

# Trello
TRELLO_API_KEY=your_trello_api_key
TRELLO_TOKEN=your_trello_token
TRELLO_BOARD_ID=your_board_id

# Notion
NOTION_API_KEY=your_notion_api_key
NOTION_DATABASE_ID=your_database_id

# ===== Data Source APIs =====
# Hunter.io for email enrichment
HUNTER_API_KEY=your_hunter_api_key

# Reddit
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret

# LinkedIn (for job scraping)
LINKEDIN_EMAIL=your_email@example.com
LINKEDIN_PASSWORD=your_linkedin_password

# Indeed
INDEED_API_KEY=your_indeed_api_key

# ===== Queue Configuration =====
QUEUE_BACKEND=memory  # memory or redis
REDIS_URL=redis://localhost:6379/0

# ===== API Rate Limiting =====
API_TIMEOUT=30
API_RETRIES=3
NOTIFICATIONS_PER_HOUR=100
DEDUP_WINDOW_HOURS=24
